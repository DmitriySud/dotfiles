// /etc/xkb/symbols/punct
partial alphanumeric_keys keypad_keys
xkb_symbols "custom" {

  // 1) Unified keypad punctuation (same in both layouts/groups)
  // Replace <KPDL> with whatever wev shows for your keypad decimal key.
  key <KPDL> {
    type[Group1] = "TWO_LEVEL",
    symbols[Group1] = [ period, comma ],
    type[Group2] = "TWO_LEVEL",
    symbols[Group2] = [ period, comma ]
  };

  // 2) Remove duplicates from the main comma/period keys
  // Replace <AB08>/<AB09> if wev shows different key names.

  // EN (Group1): disable the comma/period keys completely (optional!)
  key <AB08> { symbols[Group1] = [ NoSymbol, less ] }; // was comma/less on US
  key <AB09> { symbols[Group1] = [ NoSymbol, greater ] }; // was period/greater on US

  // RU (Group2): keep letters, remove extra punctuation levels if they exist
  // If your RU layout doesn’t put punctuation here, this still keeps the letters.
  key <AB08> { symbols[Group2] = [ Cyrillic_be, Cyrillic_BE, NoSymbol, NoSymbol ] };
  key <AB09> { symbols[Group2] = [ Cyrillic_yu, Cyrillic_YU, NoSymbol, NoSymbol ] };
};

